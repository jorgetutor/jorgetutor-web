---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { Image } from 'astro:assets';
import { SITE_AUTHOR, SITE_URL } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const blogPostingSchema = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description,
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate ?? pubDate).toISOString(),
	url: canonicalURL.toString(),
	...(heroImage && { image: new URL(heroImage.src, SITE_URL).toString() }),
	author: {
		'@type': 'Person',
		name: SITE_AUTHOR,
		url: SITE_URL,
	},
	publisher: {
		'@type': 'Person',
		name: SITE_AUTHOR,
		url: SITE_URL,
	},
};
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} schema={blogPostingSchema} />
  </head>
  <body>
    <Header />
    <main class="w-full max-w-full p-5 mb-10">

      <article class="">
        <div class="mx-auto max-w-[900px] md:py-4 text-[rgb(var(--gray-dark))] mb-4 text-left leading-none">
          <h1 class="mb-5">{title}</h1>
          <div class="mb-2 font-light">
            <p class="py-5 ">{description}</p>
            <FormattedDate date={pubDate} />
            {
              updatedDate && (
                <div class="italic">
                  Last updated on <FormattedDate date={updatedDate} />
                </div>
              )
            }
          </div>
        </div>
        <div class="w-full">
          {heroImage && (
            <Image
              width={1020}
              height={510}
              src={heroImage}
              alt={title}
              class="block mx-auto rounded-lg mb-3"
            />
          )}
        </div>
        
        <div class="mx-auto max-w-[900px] md:pr-[12rem]">
          <slot/>
          
          <a href="/blog" class="inline-block px-4 py-4 my-5 text-sm font-semibold border border-solid border-[var(--gray)] rounded-lg hover:bg-[var(--gray-light)] transition-colors duration-200">
          ← Back to Blog
          </a>
        </div>
              
      </article>
    </main>
    <Footer />
  </body>
</html>
